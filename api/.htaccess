# API Security & Configuration

# Aktiviere Rewrite Engine
RewriteEngine On

# Verhindere Directory Listing
Options -Indexes

# Nur PHP-Dateien und README erlauben, alle anderen sperren
<FilesMatch "^(?!.*\.php$|README\.md$)">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# UTF-8 Encoding
AddDefaultCharset UTF-8

# Kompression aktivieren
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# Custom Error Pages
ErrorDocument 404 "API Endpoint nicht gefunden"
ErrorDocument 500 "Interner Server Fehler"
