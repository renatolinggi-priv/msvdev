# Hochgeladene Dokumente: kein direkter HTTP-Zugriff, keine Skript-Ausfuehrung.
# Ausgeliefert werden Dateien ausschliesslich ueber api/dokument_download.php
# (mit Berechtigungspruefung). Direktzugriff per URL ist hier gesperrt.

# PHP-Ausfuehrung deaktivieren (mod_php)
<IfModule mod_php.c>
    php_admin_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_admin_flag engine off
</IfModule>

# Bekannte Skript-Endungen explizit als Text behandeln (Fallback fuer FPM)
<FilesMatch "\.(php|php3|php4|php5|php7|phtml|phar|pl|py|cgi|asp|aspx|sh|html?)$">
    SetHandler none
    ForceType text/plain
</FilesMatch>

# Direktzugriff komplett verbieten (Apache 2.4 und 2.2)
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
